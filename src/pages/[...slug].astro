---
import Layout from '../layouts/Layout.astro';
import PuckRendererView from '../components/PuckRendererView';
import { getPageData as getLocalPageData } from '../lib/puck-data';

export const prerender = false;

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const normalizedPath = pathname.startsWith('/') ? pathname : `/${pathname}`;

let pageData = null;

if (import.meta.env.DEV) {
  pageData = await getLocalPageData(normalizedPath);
} else {
  const baseEndpoint =
    import.meta.env.PUBLIC_PUCK_ENDPOINT ||
    `${Astro.site?.origin ?? ''}/.netlify/functions/puck-page`;

  const response = await fetch(`${baseEndpoint}${normalizedPath}`);
  if (response.ok) {
    pageData = await response.json();
  }
}

if (!pageData) {
  return Astro.redirect('/404', 302);
}

const pageTitle =
  pageData.root?.props?.title || normalizedPath.replace('/', '') || 'Page';
---

<Layout title={pageTitle}>
  <main class='page-content'>
    <div class='container'>
      <PuckRendererView data={pageData} />
    </div>
  </main>
</Layout>

---
import Layout from '../layouts/Layout.astro';
import CardAbout from '../components/CardAbout.astro';

export async function getStaticPaths() {
  const posts = Object.values(
    import.meta.glob('../posts/*.md', { eager: true }),
  ) as Array<{
    frontmatter: {
      slug: string;
      title: string;
      author: string;
      date: string;
      excerpt: string;
    };
    Content: any;
    url: string;
  }>;

  return posts.map((post) => ({
    params: {
      slug: post.frontmatter.slug,
    },
    props: {
      post,
    },
  }));
}

const { Content, frontmatter } = Astro.props.post as {
  Content: any;
  frontmatter: {
    title: string;
    author: string;
    date: string;
    excerpt: string;
  };
};
---

<Layout title={frontmatter.title}>
  <section class='page-content'>
    <div class='container'>
      <CardAbout>
        <a class='btn' href='/blog'>Go Back</a>
        <h2>{frontmatter.title}</h2>
        <div>
          Written by <strong>{frontmatter.author}</strong> on {
            new Date(frontmatter.date).toLocaleDateString('es')
          }
        </div>
        <Content />
      </CardAbout>
    </div>
  </section>
</Layout>

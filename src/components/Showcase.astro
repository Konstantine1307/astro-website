---
import logos from '../images/framework-logos.png?url';
import logosSmall from '../images/framework-logos-small.png?url';


export interface Props {
  heading?: string;
  text?: string;
  showExtra?: boolean;
}

const {
  heading,
  text = ' Build super fast HTML-first websites using your favorite JavaScript frameworks',
  showExtra = false,
} = Astro.props as Props;
---

<section class="showcase">
  <div class="showcase-text">
    <h1>{heading}</h1>
    <p>
      {text}
    </p>
  </div>

  {
    showExtra && (
      <>
        <div class="showcase-img">
          <img class="logos" src={`${logos}`} alt="" />
          <img class="logos-small" src={`${logosSmall}`} alt="" />
        </div>

        <p class="showcase-demo">
          <small>
            This is a demo website used for the YouTube crash course.
          </small>
        </p>
      </>
    )
  }
</section>

